    {
        "id": "nd_http_vel",
        "type": "http request",
        "z": "tab_sg",
        "name": "Write InfluxDB",
        "method": "use",
        "ret": "txt",
        "paytoqs": false,
        "url": "",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
        "headers": [],
        "x": 700,
        "y": 180,
        "wires": [
            ["nd_dbg_vel"]
        ]
    },
    {
        "id": "nd_dbg_vel",
        "type": "debug",
        "z": "tab_sg",
        "name": "Velocidade OK",
        "active": false,
        "tosidebar": true,
        "console": false,
        "tostatus": true,
        "complete": "payload",
        "targetType": "msg",
        "statusVal": "payload",
        "statusType": "auto",
        "x": 910,
        "y": 180,
        "wires": []
    },

    {
        "id": "sg_comment_3",
        "type": "comment",
        "z": "tab_sg",
        "name": "🚨 Pipeline: Alerta de Queda → Notificacao + InfluxDB",
        "info": "Recebe alertas de queda (ON/OFF), registra no InfluxDB\ne exibe no debug. Pode ser expandido para email, SMS, etc.",
        "x": 270,
        "y": 240,
        "wires": []
    },
    {
        "id": "nd_mqtt_alerta",
        "type": "mqtt in",
        "z": "tab_sg",
        "name": "Alerta Queda",
        "topic": "safeguard/queda/alerta",
        "qos": "1",
        "datatype": "utf8",
        "broker": "cfg_broker",
        "nl": false,
        "rap": false,
        "inputs": 0,
        "x": 150,
        "y": 300,
        "wires": [
            ["nd_fn_influx_alerta"],
            ["nd_switch_alerta"]
        ]
    },
    {
        "id": "nd_fn_influx_alerta",
        "type": "function",
        "z": "tab_sg",
        "name": "Alerta → Influx Line Protocol",
        "func": "const status = msg.payload;\nconst ts = Date.now();\n\nmsg.headers = {\n    'Authorization': 'Token ' + env.get('INFLUXDB_TOKEN'),\n    'Content-Type': 'text/plain; charset=utf-8'\n};\nmsg.url = env.get('INFLUXDB_URL') + '/api/v2/write?org=safeguard&bucket=sensors&precision=ms';\nmsg.method = 'POST';\nmsg.payload = 'alerta,device=esp32-001 status=\"' + status + '\" ' + ts;\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 440,
        "y": 280,
        "wires": [
            ["nd_http_alerta"]
        ]
    },
    {
        "id": "nd_http_alerta",
        "type": "http request",
        "z": "tab_sg",
        "name": "Write InfluxDB",
        "method": "use",
        "ret": "txt",
        "paytoqs": false,
        "url": "",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
        "headers": [],
        "x": 700,
        "y": 280,
        "wires": [
            []
        ]
    },
    {
        "id": "nd_switch_alerta",
        "type": "switch",
        "z": "tab_sg",
        "name": "ON / OFF",
        "property": "payload",
        "propertyType": "msg",
        "rules": [
            {
                "t": "eq",
                "v": "ON",
                "vt": "str"
            },
            {
                "t": "eq",
                "v": "OFF",
                "vt": "str"
            }
        ],
        "checkall": "true",
        "repair": false,
        "outputs": 2,
        "x": 350,
        "y": 380,
        "wires": [
            ["nd_fn_alerta_on"],
            ["nd_fn_alerta_off"]
        ]
    },
    {
        "id": "nd_fn_alerta_on",
        "type": "function",
        "z": "tab_sg",
        "name": "Formatar Alerta ON",
        "func": "msg.payload = {\n    alerta: 'QUEDA DETECTADA',\n    timestamp: new Date().toISOString(),\n    device: 'esp32-001',\n    acao: 'Notificar cuidador'\n};\nmsg.topic = 'QUEDA DETECTADA!';\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 560,
        "y": 360,
        "wires": [
            ["nd_dbg_alerta_on"]
        ]
    },
    {
        "id": "nd_fn_alerta_off",
        "type": "function",
        "z": "tab_sg",
        "name": "Formatar Status OFF",
        "func": "msg.payload = {\n    status: 'NORMAL',\n    timestamp: new Date().toISOString(),\n    device: 'esp32-001',\n    acao: 'Nenhuma acao necessaria'\n};\nmsg.topic = 'Status Normal';\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 560,
        "y": 420,
        "wires": [
            ["nd_dbg_alerta_off"]
        ]
    },
    {
        "id": "nd_dbg_alerta_on",
        "type": "debug",
        "z": "tab_sg",
        "name": "🚨 QUEDA DETECTADA!",
        "active": true,
        "tosidebar": true,
        "console": true,
        "tostatus": true,
        "complete": "payload",
        "targetType": "msg",
        "statusVal": "topic",
        "statusType": "msg",
        "x": 800,
        "y": 360,
        "wires": []
    },
    {
        "id": "nd_dbg_alerta_off",
        "type": "debug",
        "z": "tab_sg",
        "name": "✅ Status Normal",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": true,
        "complete": "payload",
        "targetType": "msg",
        "statusVal": "topic",
        "statusType": "msg",
        "x": 790,
        "y": 420,
        "wires": []
    }
]
